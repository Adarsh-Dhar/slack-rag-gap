{
  "display_information": {
    "name": "my-rag-bot (local)"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "agent_view": {},
    "bot_user": {
      "display_name": "my-rag-bot (local)",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:join",
        "channels:read",
        "chat:write",
        "im:history",
        "im:read",
        "im:write",
        "groups:history",
        "groups:read",
        "mpim:history",
        "mpim:write",
        "users:read",
        "assistant:write"
      ]
    }
  },
  "settings": {
    "socket_mode_enabled": true,
    "org_deploy_enabled": true,
    "interactivity": {
      "is_enabled": true
    },
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "app_home_opened",
        "app_context_changed"
      ]
    },
    "token_rotation_enabled": false,
    "is_mcp_enabled": false
  }
}
