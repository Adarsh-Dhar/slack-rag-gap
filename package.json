{
  "name": "my-rag-bot",
  "version": "1.0.0",
  "description": "A template for building AI-enabled Slack apps",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "check": "npx tsc --checkJs --noEmit --esModuleInterop --target esnext --module nodenext --moduleResolution nodenext app.js",
    "start": "node app.js",
    "chroma": "chroma run --path ./chroma-data --port 8000",
    "lint": "npx @biomejs/biome check *.js agent/ listeners/",
    "lint:fix": "npx @biomejs/biome check --write *.js agent/ listeners/",
    "test": "node --test test/*.js",
    "gap-detect": "node gap-detect.js",
    "staleness-detect": "node staleness-detect.js",
    "scheduler": "node scheduler.js"
  },
  "author": "Slack Technologies, LLC",
  "license": "MIT",
  "keywords": [
    "slack",
    "bolt",
    "slackapi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/slack-samples/bolt-js-assistant-template.git"
  },
  "bugs": {
    "url": "https://github.com/slack-samples/bolt-js-assistant-template/issues"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "chromadb": "^3.5.0",
    "dotenv": "~17.4.2",
    "openai": "^6.45.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@slack/cli-hooks": "^1.3.3",
    "@types/node": "^24.13.2",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.10.0+sha1.216899f511c8dfde183c7cb50b69009c779534a8"
}