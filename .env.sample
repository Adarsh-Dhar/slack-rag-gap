# Optional, uncomment and set when running without the Slack CLI (npm start).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL

# Required, set your OpenAI API key.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Optional: GitHub token for code-extraction, git-blame-owner, and code-staleness features.
# GITHUB_TOKEN=YOUR_GITHUB_TOKEN

# Optional: GitHub repo owner/name for git blame lookups (defaults to Adarsh-Dhar/my-rag-bot).
# GITHUB_REPO_OWNER=Adarsh-Dhar
# GITHUB_REPO_NAME=my-rag-bot

# Optional: Slack user ID of the on-call rotation fallback (used if on-call.json doesn't exist).
# STAKEHOLDER_USER_ID=YOUR_STAKEHOLDER_USER_ID

# Optional: Days of inactivity before a code file is considered stale (default: 90).
# CODE_STALE_DAYS=90

# Optional: Base staleness threshold for doc usage (default: 0.3).
# STALENESS_THRESHOLD=0.3

# Optional: Multiplier for low-frequency scheduler jobs (default: 30).
# LOW_FREQ_MULTIPLIER=30
