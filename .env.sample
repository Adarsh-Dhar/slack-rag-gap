# Optional, uncomment and set when running without the Slack CLI (npm start).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL

# Required. GitHub personal access token with "models: read" permission.
# Create one at https://github.com/settings/tokens -> Fine-grained tokens
GITHUB_TOKEN=YOUR_GITHUB_TOKEN

# Slack user ID (e.g. U0123ABC) of whoever should review auto-drafted doc stubs.
# Find it via Slack profile > "Copy member ID".
STAKEHOLDER_USER_ID=

# Slack user ID of the app creator. Only this user can assign initial doc
# ownership. The app creator and the current doc owner can transfer ownership.
APP_CREATOR_ID=

# Optional: override the ChromaDB server URL (default: http://localhost:8000)
# CHROMA_URL=http://localhost:8000

# Optional: how often (ms) the in-process scheduler runs gap-detect and
# staleness-detect. Default is 60000 (60s), meant for local dev/demo.
# Use a much longer interval (e.g. 900000 = 15 min) in real deployments.
# SCHEDULER_INTERVAL_MS=60000

# Optional: set to "false" to disable the in-process scheduler entirely
# (e.g. if you run scheduler.js as a separate process, or via external cron).
# ENABLE_SCHEDULER=true
